<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: #0f1115;
  font-family: 'Segoe UI', sans-serif;
  display: flex;
  justify-content: center;
  padding: 30px;
  color: #e6e6e6;
}

.wrap {
  width: 100%;
  max-width: 900px;
}

/* NAV */
.nav {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}

.era-btn {
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid #2a2f3a;
  background: #1a1d24;
  color: #9aa4b2;
  cursor: pointer;
  transition: 0.2s;
  font-size: 13px;
}

.era-btn:hover {
  background: #2a2f3a;
  color: #fff;
}

.era-btn.active {
  background: #4da3ff;
  color: white;
  border-color: #4da3ff;
}

/* PROGRESS */
.progress {
  height: 6px;
  background: #2a2f3a;
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 20px;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #4da3ff, #6ee7ff);
  width: 0%;
  transition: 0.4s;
}

/* CARD */
.card {
  background: #1a1d24;
  border-radius: 18px;
  padding: 22px;
  box-shadow: 0 12px 35px rgba(0,0,0,0.4);
  animation: fade 0.3s ease;
}

@keyframes fade {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}

/* HEADER */
.badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11px;
  margin-bottom: 10px;
}

.title {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 6px;
}

.desc {
  font-size: 14px;
  color: #cbd5e1;
  line-height: 1.6;
}

/* STATS */
.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin: 16px 0;
}

.stat {
  background: #2a2f3a;
  border-radius: 10px;
  padding: 12px;
}

.stat-val {
  font-size: 18px;
  font-weight: 600;
}

.stat-lbl {
  font-size: 11px;
  color: #9aa4b2;
}

/* PEOPLE */
.section-title {
  font-size: 12px;
  color: #9aa4b2;
  margin: 12px 0 8px;
  text-transform: uppercase;
}

.person {
  display: flex;
  gap: 10px;
  margin: 8px 0;
}

.avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

/* CURIOSITY */
.curiosity {
  background: #1f2f45;
  padding: 12px;
  border-radius: 10px;
  margin-top: 14px;
  border-left: 3px solid;
}

.machine {
  font-size: 12px;
  color: #9aa4b2;
  margin-top: 10px;
  font-style: italic;
}

/* BUTTONS */
.actions {
  display: flex;
  gap: 10px;
  margin-top: 16px;
  flex-wrap: wrap;
}

.btn {
  padding: 10px 14px;
  border-radius: 10px;
  border: none;
  background: #2a2f3a;
  color: white;
  cursor: pointer;
  transition: 0.2s;
  flex: 1;
}

.btn:hover {
  background: #3a4150;
}

.btn.primary {
  background: #4da3ff;
}

.btn.primary:hover {
  background: #3b8eea;
}
</style>

<div class="wrap">

  <div class="nav" id="nav"></div>
  <div class="progress"><div class="progress-bar" id="bar"></div></div>
  <div id="content"></div>

</div>

<script>
const eras = [...]; // mantém seu array original

let current = 0;

function render() {
  const e = eras[current];

  // NAV
  document.getElementById('nav').innerHTML = eras.map((era, i) =>
    `<button class="era-btn ${i===current?'active':''}" onclick="go(${i})">${era.label}</button>`
  ).join('');

  // PROGRESS
  const percent = ((current+1)/eras.length)*100;
  document.getElementById('bar').style.width = percent + '%';

  // CONTENT
  document.getElementById('content').innerHTML = `
    <div class="card">

      <div class="badge" style="background:${e.badgeColor};color:${e.badgeText}">
        ${e.period}
      </div>

      <div class="title">${e.tagline}</div>
      <div class="desc">${e.desc}</div>

      <div class="stat-row">
        ${e.stats.map(s=>`
          <div class="stat">
            <div class="stat-val">${s.val}</div>
            <div class="stat-lbl">${s.lbl}</div>
          </div>
        `).join('')}
      </div>

      <div class="section-title">Personagens</div>
      ${e.people.map(p=>`
        <div class="person">
          <div class="avatar" style="background:${p.bg};color:${p.txt}">${p.init}</div>
          <div>
            <div style="font-size:13px;font-weight:600">${p.name}</div>
            <div style="font-size:12px;color:#9aa4b2">${p.role}</div>
          </div>
        </div>
      `).join('')}

      <div class="curiosity" style="border-color:${e.badgeColor}">
        ${e.curiosity}
      </div>

      <div class="machine">${e.machine}</div>

      <div class="actions">
        ${current>0 ? `<button class="btn" onclick="go(${current-1})">← Voltar</button>` : ''}
        ${current<eras.length-1 
          ? `<button class="btn primary" onclick="go(${current+1})">Próximo →</button>`
          : `<button class="btn primary">Finalizar</button>`}
        <button class="btn">${e.ask} ↗</button>
      </div>

    </div>
  `;
}

function go(i){ current = i; render(); }

render();
</script>
